# ============================================
# TikTok 无货源带货自动化系统 - 环境配置
# ============================================

# --------------------------------------------
# OpenAI API 配置 (必需)
# 用于生成带货脚本和配音
# 获取地址: https://platform.openai.com/api-keys
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# --------------------------------------------
# TikTok API 配置 (可选 - 用于API发布)
# 获取方式: TikTok for Developers
# --------------------------------------------
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# TikTok 账号配置 (用于Selenium/Playwright模拟发布)
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password

# --------------------------------------------
# Amazon API 配置 (可选)
# Rainforest API: https://www.rainforestapi.com/
# 用于获取真实亚马逊商品数据
# --------------------------------------------
RAINFOREST_API_KEY=your_rainforest_api_key

# --------------------------------------------
# TikTok 数据服务配置 (可选)
# 用于获取真实热门商品数据
# 可选服务: FastMoss, Kalodata, EchoTik
# --------------------------------------------
TIKTOK_DATA_API_KEY=your_tiktok_data_api_key
TIKTOK_DATA_API_URL=https://api.example.com

# --------------------------------------------
# 第三方发布工具配置 (可选)
# 如: Inflact, TokAutomator, CombBoost
# --------------------------------------------
THIRD_PARTY_API_KEY=your_third_party_api_key

# --------------------------------------------
# 目录配置
# --------------------------------------------
OUTPUT_DIR=./output
TEMP_DIR=./temp
LOGS_DIR=./logs

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=INFO

# --------------------------------------------
# 自动化配置
# --------------------------------------------
# 每次运行处理的最大商品数
MAX_PRODUCTS_PER_RUN=3
# 利润率阈值 (低于此值跳过)
MIN_PROFIT_MARGIN=30
# 定时运行间隔 (小时)
SCHEDULE_INTERVAL_HOURS=6
